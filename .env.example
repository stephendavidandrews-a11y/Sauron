# Sauron — Environment Variables
# Copy to .env and fill in real values

# ── Security ──
SAURON_API_KEY=your-api-key-here
NETWORKING_APP_API_KEY=your-networking-app-api-key

# ── Claude API ──
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Email (Gmail App Password) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Your Name <you@example.com>

# ── Google Calendar OAuth ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REFRESH_TOKEN=1//your-refresh-token

# ── Hugging Face (pyannote models) ──
HF_TOKEN=hf_your-token

# ── Config Overrides (optional — defaults match Mac Mini production) ──
# SAURON_BASE_DIR=/Users/stephen/Documents/Website/Sauron
# SAURON_DB_PATH=/Users/stephen/Documents/Website/Sauron/data/sauron.db
# SAURON_ARCHIVE_DIR=/Volumes/External/sauron/archive
# SAURON_PORT=8003
# NETWORKING_APP_URL=http://localhost:3000
# SAURON_WHISPER_MODEL=medium.en
# SAURON_TRIAGE_MODEL=claude-haiku-4-5-20251001
# SAURON_EXTRACTION_MODEL=claude-sonnet-4-6
# SAURON_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# SAURON_MORNING_EMAIL_RECIPIENT=stephen@stephenandrews.org
# SAURON_GOOGLE_CALENDAR_ID=stephen@stephenandrews.org
