"""Beliefs API — query beliefs, contested beliefs, topic search, what-changed.

Endpoints:
  GET /beliefs              — list all active beliefs
  GET /beliefs/contact/{id} — beliefs for a specific contact
  GET /beliefs/topic/{t}    — search beliefs by topic
  GET /beliefs/contested    — list contested beliefs
  GET /beliefs/what-changed/{entity_type}/{entity_id} — what-changed snapshots
"""

import logging

from fastapi import APIRouter

from sauron.db.connection import get_connection
from sauron.intelligence.beliefs import (
    get_beliefs_for_contact,
    get_beliefs_for_topic,
    get_contested_beliefs,
    get_what_changed_for_entity,
)

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/beliefs", tags=["beliefs"])


@router.get("")
async def list_beliefs(limit: int = 50):
    """List all active beliefs."""
    conn = get_connection()
    try:
        rows = conn.execute(
            """SELECT b.*, uc.canonical_name as entity_name
               FROM beliefs b
               LEFT JOIN unified_contacts uc ON b.entity_id = uc.id
               WHERE b.status NOT IN ('superseded')
               ORDER BY b.last_changed_at DESC
               LIMIT ?""",
            (limit,),
        ).fetchall()
        return [dict(r) for r in rows]
    finally:
        conn.close()


@router.get("/contact/{contact_id}")
async def beliefs_for_contact(contact_id: str, limit: int = 30):
    """Get beliefs for a specific contact."""
    return get_beliefs_for_contact(contact_id, limit)


@router.get("/topic/{topic}")
async def beliefs_for_topic(topic: str, limit: int = 20):
    """Search beliefs by topic."""
    return get_beliefs_for_topic(topic, limit)


@router.get("/contested")
async def contested_beliefs(limit: int = 20):
    """Get contested beliefs."""
    return get_contested_beliefs(limit)


@router.get("/what-changed/{entity_type}/{entity_id}")
async def what_changed(entity_type: str, entity_id: str, days: int = 30):
    """Get what-changed snapshots for an entity."""
    return get_what_changed_for_entity(entity_type, entity_id, days)
